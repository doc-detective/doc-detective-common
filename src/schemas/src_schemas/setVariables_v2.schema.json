{
  "title": "setVariables",
  "type": "object",
  "description": "Load environment variables from a `.env` file.",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID of the step."
    },
    "description": {
      "type": "string",
      "description": "Description of the step."
    },
    "action": {
      "type": "string",
      "const": "setVariables",
      "description": "Action to perform."
    },
    "retryLimit": {
      "type": "integer",
      "description": "Maximum number of times to retry the step if it fails."
    },
    "retryDelay": {
      "type": "integer",
      "description": "Number of milliseconds to wait before retrying the step."
